{
  "_version": "1.83.0",
  "sap.app": {
    "id": "managerdashboard",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "Manager Dashboard",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.22.0",
      "toolsId": "c6f7a6be-8ff1-4b5c-9c74-70e4725d3a7a"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/expense/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "manager-dashboard-display": {
          "semanticObject": "manager-dashboard",
          "action": "display",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.148.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {},
        "sap.f": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "managerdashboard.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "ManagerDashboardList",
          "target": [
            "ManagerDashboardList"
          ]
        },
        {
          "pattern": "ManagerDashboard({key}):?query:",
          "name": "ManagerDashboardObjectPage",
          "target": [
            "ManagerDashboardList",
            "ManagerDashboardObjectPage"
          ]
        }
      ],
      "targets": {
        "ManagerDashboardList": {
          "type": "Component",
          "id": "ManagerDashboardList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/ManagerDashboard",
              "variantManagement": "Page",
              "navigation": {
                "ManagerDashboard": {
                  "detail": {
                    "route": "ManagerDashboardObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  },
                  "actions": {
                    "DataFieldForAction::ExpenseService.approveClaim": {
                      "enableOnSelect": "single"
                    },
                    "DataFieldForAction::ExpenseService.rejectClaim": {
                      "enableOnSelect": "single"
                    }
                  }
                }
              },
              "defaultTemplateAnnotationPath": "com.sap.vocabularies.UI.v1.SelectionPresentationVariant#tableView",
              "initialLoad": "Enabled"
            }
          }
        },
        "ManagerDashboardObjectPage": {
          "type": "Component",
          "id": "ManagerDashboardObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/ManagerDashboard",
              "navigation": {},
              "enableLazyLoading": true,
              "additionalSemanticObjects": {},
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.FieldGroup#ClaimDetails": {
                  "actions": {
                    "DataFieldForAction::ExpenseService.approveClaim": {
                      "priority": "High"
                    },
                    "DataFieldForAction::ExpenseService.rejectClaim": {
                      "priority": "High"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "expensemanagement.service"
  }
}
